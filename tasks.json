[
  {
    "label": "setup new worktree",
    "command": "/bin/bash",
    "args": ["$HOME/.config/zed/setup-worktree.sh"],
    "hooks": ["create_worktree"],
    "reveal": "no_focus",
    "hide": "on_success",
    "env": {
      "HOME": "$HOME",
      "GIT_CONFIG_GLOBAL": "$HOME/.gitconfig",
      "PATH": "/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$HOME/Library/Application Support/Herd/bin"
    }
  }
]
